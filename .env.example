BOT_TOKEN=your_telegram_bot_token
SUPER_ADMIN_ID=123456789
DATABASE_PATH=./data/bot.db
TIMEZONE=Asia/Shanghai
PUBLISH_TIME=14:00
COOLDOWN_SECONDS=30

# MiniApp web 服务（P0）。默认关闭，开启前现有 bot 行为不变。
# WEB_ENABLED=true 时与 polling 同进程并起 aiohttp，监听 WEB_HOST:WEB_PORT
# （生产应由 Nginx/Caddy 终止 TLS 后反代到 127.0.0.1:WEB_PORT）。
WEB_ENABLED=false
WEB_HOST=127.0.0.1
WEB_PORT=8080
